    <title>The Inkwell | Immersive Stories</title>
    <style>
        :root {
            --bg-color: #fdfcf8;
            --text-color: #2c2c2c;
            --accent-color: #8b4513;
            --serif-font: 'Georgia', serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: var(--serif-font);
            line-height: 1.8;
            margin: 0;
            padding: 0;
        }

        header {
            padding: 4rem 2rem;
            text-align: center;
            border-bottom: 1px solid #eee;
        }

        h1 {
            font-size: 3rem;
            letter-spacing: -1px;
            margin: 0;
        }

        nav {
            margin-top: 1rem;
        }

        nav a {
            margin: 0 15px;
            text-decoration: none;
            color: var(--accent-color);
            font-weight: bold;
        }

        main {
            max-width: 700px;
            margin: 0 auto;
            padding: 2rem;
        }

        .story-card {
            margin-bottom: 4rem;
        }

        .story-card h2 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .meta {
            font-style: italic;
            color: #666;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .excerpt {
            font-size: 1.1rem;
        }

        .read-more {
            display: inline-block;
            margin-top: 1rem;
            color: var(--accent-color);
            text-decoration: none;
            border-bottom: 1px solid var(--accent-color);
        }

        footer {
            text-align: center;
            padding: 3rem;
            font-size: 0.8rem;
            color: #999;
        }
    </style>
</head>
